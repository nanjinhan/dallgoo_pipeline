# ============================================================
#  recording-pipeline 환경변수 템플릿 (값 없이 구조만 — git 포함)
#  실제 값은 .env 에 채운다. .env 는 .gitignore 로 제외됨.
# ============================================================

# --- go2rtc / 백엔드 ---
GO2RTC_URL=
BACKEND_HOST=
BACKEND_PORT=
RECORDINGS_DIR=

# 녹화 대상 카메라 (콤마 구분). go2rtc.yaml 의 stream 키와 이름이 일치해야 한다.
#   예: CAMERAS=cam_1,cam_2
CAMERAS=

# --- SFTP / NAS (VPN 연결 후 접속) ---
SFTP_HOST=
SFTP_PORT=
SFTP_USER=
SFTP_KEY=
SFTP_DEST=
# 개인키 종류: ed25519 | rsa | auto
SFTP_KEY_TYPE=

# --- VPN 자동 연결/해제 (스케줄러 무인 실행용) ---
# VPN_AUTOMANAGE=1 이면 스케줄러가 OpenVPN 을 직접 연결/해제한다.
# 0 이면 VPN 이 이미 연결돼 있다고 가정한다(M5 수동 연결 단계).
VPN_AUTOMANAGE=
OPENVPN_EXE=
OVPN_CONFIG=
# VPN 연결 후 SFTP_HOST 도달까지 최대 대기(초)
VPN_WAIT_SECONDS=
