@echo off
REM ============================================================
REM  NAS 전송 (수동) — 더블클릭하면 안 보낸 세션을 전부 전송
REM  ⚠️ 실행 전 OpenVPN Connect 로 VPN 연결돼 있어야 함
REM  흐름: VPN 확인 → 압축 → SFTP 업로드 → 체크섬 검증 → 성공분 sent\ 이동
REM ============================================================
cd /d "%~dp0"

echo ============================================
echo   NAS 전송 시작
echo   (VPN 이 연결돼 있어야 합니다)
echo ============================================
echo.

python -m scheduler.run_transfer

echo.
echo ============================================
echo   전송 끝. 위 로그에서 "전송 성공" 확인.
echo   보낸 세션은 recordings\sent\ 로 이동됨.
echo ============================================
pause
